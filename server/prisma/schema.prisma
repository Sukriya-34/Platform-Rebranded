generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//create a strict list of allowed roles
enum UserRole {
  Learner
  ContentCreator
  Admin
}



model User {
  id            Int     @id @default(autoincrement())
  fullName      String  
  email         String  @unique
  password      String

  role          UserRole @default(Learner)
  createdAt     DateTime @default(now())

  isVerified    Boolean  @default(false) //everyone starts as unverifed
  otpCode       String?  // The 6-digit code
  otpExpiry     DateTime? // when the code expires

}
