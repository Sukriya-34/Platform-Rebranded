generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"

}

model User {
  id             Int      @id @default(autoincrement())
  fullName       String
  personalEmail  String   @unique
  platformEmail  String?  @unique
  password       String
  role           String   @default("Learner")
  createdAt      DateTime @default(now())
}
